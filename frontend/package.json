    "next": "15.5.18",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "server-only": "0.0.1",
    "tailwind-merge": "3.3.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/node": "22.19.1",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.21",
    "openapi-typescript": "7.10.1",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.18",
    "typescript": "5.9.3"
  }
