AUTH_PROJECT_NAME=auth

AUTH_POSTGRES_USER=postgres
AUTH_POSTGRES_PASSWORD=postgres
AUTH_POSTGRES_DB=postgres
AUTH_POSTGRES_HOST=auth-postgres
AUTH_POSTGRES_PORT=5432

AUTH_REDIS_HOST=auth-redis
AUTH_REDIS_PORT=6379

AUTH_LOGGING_LEVEL=INFO
AUTH_CONSOLE_LOGGING_LEVEL=DEBUG

# OAuth — get your own credentials at https://oauth.yandex.ru / https://console.cloud.google.com
AUTH_YANDEX_CLIENT_ID=<your-yandex-client-id>
AUTH_YANDEX_CLIENT_SECRET=<your-yandex-client-secret>
AUTH_GOOGLE_CLIENT_ID=<your-google-client-id>
AUTH_GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# TimeDelta format [±]P[DD]DT[HH]H[MM]M[SS]S
AUTH_ACCESS_TOKEN_LIFETIME=P0DT12H00M0S
AUTH_REFRESH_TOKEN_LIFETIME=P15DT12H00M0S

AUTH_RSA_PRIVATE_PATH=/run/secrets/rsa.private
AUTH_RSA_PUBLIC_PATH=/run/secrets/rsa.pub

AUTH_DEBUG=False

AUTH_JAEGER_HOST=
AUTH_JAEGER_PORT=
